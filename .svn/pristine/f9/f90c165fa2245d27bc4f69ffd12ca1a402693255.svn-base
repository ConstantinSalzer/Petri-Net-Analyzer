package exceptions;

/**
 * Exception, falls eine Kante mit einer ID bereits existiert
 */
public class DoppelteKanteException extends RuntimeException{
	private static final long serialVersionUID = 1L;

	/**
	 * Konstruktor der Exception, gibt die passende Fehlermeldung aus
	 * @param id
	 * 		ID des Elements, dass die Fehlermeldung ausgelöst hat
	 */
	public DoppelteKanteException (String id) {
		super ("Kante mit ID: " + id + " existiert bereits!");
	}

}
