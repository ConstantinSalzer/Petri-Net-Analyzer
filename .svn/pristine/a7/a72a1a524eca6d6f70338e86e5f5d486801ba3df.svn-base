package GUI;

import java.awt.BorderLayout;
import java.awt.Dimension;
import java.awt.Toolkit;
import java.awt.event.MouseAdapter;
import java.awt.event.MouseEvent;
import java.awt.event.MouseWheelEvent;
import java.awt.event.MouseWheelListener;
import java.io.File;
import java.util.Arrays;
import java.util.List;

import javax.swing.ImageIcon;
import javax.swing.JButton;
import javax.swing.JFileChooser;
import javax.swing.JFrame;
import javax.swing.JLabel;
import javax.swing.JMenu;
import javax.swing.JMenuBar;
import javax.swing.JMenuItem;
import javax.swing.JOptionPane;
import javax.swing.JPanel;
import javax.swing.JToolBar;
import javax.swing.SwingConstants;
import javax.swing.filechooser.FileNameExtensionFilter;

import org.graphstream.ui.swing_viewer.SwingViewer;
import org.graphstream.ui.swing_viewer.ViewPanel;
import org.graphstream.ui.view.Viewer;
import org.graphstream.ui.view.ViewerPipe;


import datenstruktur_Petrinetz.Petrinetz;
import datenstruktur_Petrinetz.SpecializedPNMLParser;

public class Rahmen extends JFrame{
	
	private static final long serialVersionUID = 7L;
	
	
	private JLabel statusLabel;
	
	private JLabel titelLabel;
	
	private Graf graf;
	
	private JPanel jpnlGraph;
	
	private ViewPanel viewPanel;
	
	private File letzteGeöffneteDatei;
	private File aktuelleDatei;
	
	private JMenuBar Menü;
	private JMenu Datei;
	private JMenu Hilfe;
	private JMenuItem Info;
	private JMenuItem Öffnen;
	private JMenuItem NeuLaden;
	private JMenuItem Beenden;

	private JToolBar toolBar;
	private JButton nächstepnmlDatei;
	private JButton vorherigepnmlDatei;
	private JButton löscheEG;
	private JButton markePlus;
	private JButton markeMinus;
	private JButton resetAnfangsmarkierung;
	

	private JFileChooser chooser;
	
	
	public Rahmen (String titel) {
		super(titel);
		
		
		this.setLayout(new BorderLayout());
		
		statusLabel = new JLabel("Java.version = " + System.getProperty("java.version") + "  |  user.dir = " +System.getProperty("user.dir"));
		
		this.add(statusLabel, BorderLayout.SOUTH);
		
		double relativeHöhe = 0.6;
		double Seitenverhältnis = 16.0/10.0;
		Dimension bildschirmGröße = Toolkit.getDefaultToolkit().getScreenSize();
		int h = (int) (bildschirmGröße.height * relativeHöhe);
		int b = (int) (h * Seitenverhältnis);
		setBounds((bildschirmGröße.width - b) / 2, (bildschirmGröße.height -h) / 2, b, h);
		this.setDefaultCloseOperation (JFrame.EXIT_ON_CLOSE);
		
		titelLabel = new JLabel("Constantin Salzer" + "  |  q3756556", SwingConstants.CENTER);
		this.add(titelLabel, BorderLayout.NORTH);	
		
		chooser = new JFileChooser("../ProPra-SS25-Basis/Beispiele");
		FileNameExtensionFilter filter = new FileNameExtensionFilter(
			    "PNML Dateien (*.pnml)", "pnml"
			);
		chooser.setFileFilter(filter);
		
		Menü = new JMenuBar();
		this.setJMenuBar(Menü);
		Hilfe = new JMenu("Hilfe");
		Info = new JMenuItem ("Info");
		Menü.add(Hilfe);
		Hilfe.add(Info);
		Info.addActionListener(e->{
			JOptionPane.showMessageDialog(new JFrame(),
					"Java.version = " +System.getProperty("java.version")
					+"\nuser.dir = " +System.getProperty("user.dir")
					);
		});
		
		Datei = new JMenu("Datei");
		Öffnen = new JMenuItem("Öffnen");
		Menü.add(Datei);
		Datei.add(Öffnen);
		Öffnen.addActionListener(e->{		
			int result = chooser.showOpenDialog(this);
			
			if(result == JFileChooser.APPROVE_OPTION) {
				letzteGeöffneteDatei = chooser.getSelectedFile();
				updateGraf(letzteGeöffneteDatei);
			}
		});
		NeuLaden = new JMenuItem("Neu Laden");
		Datei.add(NeuLaden);
		NeuLaden.addActionListener(e->{
			if (letzteGeöffneteDatei == null) {
				System.out.println("Sie müssen zuerst eine Datei öffnen");
			} else {
				updateGraf(letzteGeöffneteDatei);
			}
		});
		
		Beenden = new JMenuItem("Beenden");
		Datei.add(Beenden);
		Beenden.addActionListener(e->{
			System.exit(0);
		});
		
		toolBar = new JToolBar();
		this.add(toolBar, BorderLayout.NORTH);
		toolBar.addSeparator();
		
		
	
		ImageIcon vorherigeIcon = new ImageIcon("resources/Bilder/vorherigePNMLDatei.png");
		vorherigepnmlDatei = new JButton(vorherigeIcon);
		vorherigepnmlDatei.setToolTipText("öffne alphabetisch vorherige PNML-Datei aus dem zuletzt verwendeten Verzeichnis.");
		toolBar.add(vorherigepnmlDatei);
		vorherigepnmlDatei.addActionListener(e->{
			ladeNachbarDatei(false);
		});
		
		//ausnahmen falls nur eine Datei in verzeichnis und falls noch keine datei eingelesen, außerdem noch nächstepnmlDatei reparieren
		ImageIcon nächsteIcon = new ImageIcon ("resources/Bilder/nächstePNMLDatei.png");
		nächstepnmlDatei = new JButton(nächsteIcon);
		nächstepnmlDatei.setToolTipText("öffne alphabetisch nächste PNML-Datei aus dem zuletzt verwendeten Verzeichnis");
		toolBar.add(nächstepnmlDatei);
		nächstepnmlDatei.addActionListener(e->{
			ladeNachbarDatei(true);
		});
		
		ImageIcon lösche = new ImageIcon ("resources/Bilder/löscheEG.png");
		löscheEG = new JButton(lösche);
		löscheEG.setToolTipText("lösche aktuellen Erreichbarkeits-Grafen und setze markierung auf Anfangsmarkierung zurück");
		toolBar.add(löscheEG);
		
		ImageIcon plus = new ImageIcon ("resources/Bilder/plus.png");
		markePlus = new JButton(plus);
		markePlus.setToolTipText("erhöhe die Anzahl der Marken einer Stelle um 1");
		toolBar.add(markePlus);
		
		ImageIcon minus = new ImageIcon ("resources/Bilder/minus.png");
		markeMinus = new JButton(minus);
		markeMinus.setToolTipText("verringere die Anzahl der Marken einer Stelle um 1");
		toolBar.add(markeMinus);
		
		ImageIcon reset = new ImageIcon("resources/Bilder/reset.png");
		resetAnfangsmarkierung = new JButton (reset);
		resetAnfangsmarkierung.setToolTipText("setze die die Markierung auf die Anfangsmarkierung zurück");
		toolBar.add(resetAnfangsmarkierung);
		
		this.setVisible(true);
	}
	
	private void updateGraf(File pnmlDatei) {
		aktuelleDatei = pnmlDatei;
		if (jpnlGraph != null) {
			this.remove(jpnlGraph);
		}
		SpecializedPNMLParser speziellerpnmlParser = new SpecializedPNMLParser(pnmlDatei);
		speziellerpnmlParser.initParser();
		speziellerpnmlParser.parse();
		this.graf=new Graf(speziellerpnmlParser.getPetrinetz());
		initPanelGraph();
		
		jpnlGraph = new JPanel (new BorderLayout());
		jpnlGraph.add(BorderLayout.CENTER, viewPanel);
		this.add(jpnlGraph, BorderLayout.CENTER);
		
		this.revalidate();
		this.repaint();
	}
	
	private void ladeNachbarDatei (boolean nächste) {
		if (letzteGeöffneteDatei == null) {
			System.out.println("Sie müssen zuerst eine Datei öffnen");
		} else {
			File Verzeichnis = aktuelleDatei.getParentFile();
			File[] listeDateien = Verzeichnis.listFiles((dir, name) -> name.toLowerCase().endsWith(".pnml"));
			List<File> pnmlDateien = Arrays.asList(listeDateien);
			pnmlDateien.sort((f1, f2) -> f1.getName().compareToIgnoreCase(f2.getName()));
			int aktuellerIndex = 0;
			for (int i = 0; i < pnmlDateien.size(); i++) {
				if (pnmlDateien.get(i).equals(aktuelleDatei)) {
					aktuellerIndex = i;
				}
			}
			int neueIndex;
		    if (nächste) {
		        neueIndex = (aktuellerIndex + 1) % pnmlDateien.size(); // Kreisförmig weiter
		    } else {
		        neueIndex = (aktuellerIndex - 1 + pnmlDateien.size()) % pnmlDateien.size(); // Kreisförmig zurück
		    }
		    updateGraf(pnmlDateien.get(neueIndex));
		}
	}
	
	private void initPanelGraph() {
		SwingViewer viewer = new SwingViewer(graf,
				Viewer.ThreadingModel.GRAPH_IN_ANOTHER_THREAD);
		
		graf.setAttribute("ui.quality");
		graf.setAttribute("ui.antialias");
		
		viewer.disableAutoLayout();
		
		viewPanel = (ViewPanel) viewer.addDefaultView(false);
		
		ViewerPipe viewerPipe = viewer.newViewerPipe();
		
		ClickListener clickListener = new ClickListener(this);
		
		viewerPipe.addViewerListener(clickListener);
		
		viewPanel.addMouseListener(new MouseAdapter() {
			
			@Override
			public void mousePressed(MouseEvent me) {
				System.out.println("Rahmen - mousePressed: " + me);
				viewerPipe.pump();
			}
			
			@Override
			public void mouseReleased(MouseEvent me) {
				System.out.println("Rahmen - mouseReleased: " +me);
				viewerPipe.pump();
			}
		});
		
		viewPanel.addMouseWheelListener(new MouseWheelListener() {
			public void mouseWheelMoved(MouseWheelEvent e) {
				double zoomLevel = viewPanel.getCamera().getViewPercent();
				if (e.getWheelRotation() == -1) {
					zoomLevel -= 0.1;
					if (zoomLevel < 0.1) {
						zoomLevel = 0.1;
					}
				}
				if (e.getWheelRotation() == 1) {
					zoomLevel += 0.1;
				}
				viewPanel.getCamera().setViewPercent(zoomLevel);
			}
		});
	}
	public void KnotenGedruckt(String id) {
		
	}
}
