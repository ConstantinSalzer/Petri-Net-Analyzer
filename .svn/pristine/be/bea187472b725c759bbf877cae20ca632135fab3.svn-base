/*
	Dies ist die css-Datei, in der das Layout des Graphen beschrieben ist.
*/

/*
	Style-Angabe fuer einen Knoten
*/
node {
	size: 30px;
	
	fill-color: #99ccff;
	
	text-color: #003366;
	text-size: 18;
	text-offset: -10,-5;
	text-alignment: under;
	
	fill-color: white;
	
	stroke-mode: plain;
	stroke-color: #003366;
	stroke-width: 1px;
}

node.Transition {
	shape: box;
}

/*
   zusaetzliches Attribut "highlight" fuer einen Knoten, der
   hervorgehoben werden soll
*/
node.highlight {
	shape: box;
	text-style: bold;		
	stroke-color: #0000ff;
	stroke-width: 3px;
}


/*
   zusaetzliches Attribut "bild" fuer einen Knoten mit einer Abbildung
*/
node.bild {
	shape: rounded-box;
	size: 50;
	fill-mode: image-scaled;
	fill-image: url('images/logo_grau.png');
}

/*
	Style-Angabe fuer eine Kante
*/
edge {
	fill-color: #003366;
	text-color: #003366;
	arrow-shape: arrow;
	arrow-size: 9px, 6px;
	text-size:  12;
	text-color: purple;
}

/*
	Style-Angabe fuer ein Sprite, dass als Label fuer eine Kante benutzt wird
*/
sprite.edgeLabel {
	shape: box;
	fill-color: rgb(200, 255, 200);
	size: 60,20;
	text-size: 12;
	text-alignment: center;
	text-offset: 0,-3;
}


/*
	Style-Angabe fuer ein Sprite, das einen Knoten markiert
*/
sprite.mark {
	shape: cross;   
	fill-color: rgba(255,0,0,175);

	/*
		Die Groesse der Markierung muss kleiner sein als die Groesse des Knotens (siehe "node").
		Ansonsten laesst sich das kleine rote Kreuz vom Knoten "wegziehen".
	*/
	size: 28;

	z-index: 5;
}