package datenstruktur_Petrinetz;
import java.util.HashMap;

public class Petrinetz {
	public HashMap<String, Transition> Transitionen;
	public HashMap<String, Stelle> Stellen;
	public HashMap<String, Kante> Kanten;
	public HashMap<String, Stelle> Anfangsmarkierung;
	
	public Petrinetz() {
		this.Transitionen = new HashMap<String, Transition>();
		this.Stellen = new HashMap<String, Stelle>();
		this.Kanten = new HashMap<String, Kante>();
	}
	
	void addTransition(Transition transition) {
		Transitionen.put(transition.id, transition);
	}
	
	public void neueAnfangsmarkierung() {
		Anfangsmarkierung = Stellen;
	}
	
	void addStelle(Stelle stelle) {
		Stellen.put(stelle.id, stelle);
	}
	
	void addKanten(Kante kante) {
		Kanten.put(kante.id, kante);
	}
	
	public void transitionSchalten (String id) {
		Transition transition = Transitionen.get(id);
		if (!transition.istAktiviert()) {
			System.out.println("Transition muss aktiviert sein!");
		} else {
			for (Kante kante: Kanten.values()) {
				if (kante.transition.equals(transition)) {
					if (kante.stelleIstQuelle) {
						kante.stelle.verringereMarkenzahl();
					} else {
						kante.stelle.erhöheMarkenzahl();
					}
				}
			}
		}
	}
	
	void überprüfeAktivierbarkeit() {
		for (Kante kante: Kanten.values()) {
			if (kante.stelleIstQuelle()) {
				if (kante.getStelle().getMarkenzahl()>0) {
					kante.getTransition().aktiviere();
				} else {
					kante.getTransition().deaktiviere();
				}
			}
		}
	}
}
