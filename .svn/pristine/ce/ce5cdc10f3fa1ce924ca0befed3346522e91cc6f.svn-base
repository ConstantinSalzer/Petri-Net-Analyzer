package datenstruktur;

//Mutterklasse für Kanten in Petrinetzen und Erreichbarkeitsgraphen

public class Kante {
	
	//variable der Klasse
	private String id;
	
	
	//Konstruktor der Klasse
	
	public Kante(String id) {
		this.id= id;
	}
	
	//getter der Id-Variable
	
	public String getId() {
		return id;
	}
}