		AnalyseMehrerDateien = new JMenuItem("Analyse mehrerer Dateien");
		Datei.add(AnalyseMehrerDateien);
		AnalyseMehrerDateien.addActionListener(e-> {
			chooser.setMultiSelectionEnabled(true);
			int result = chooser.showOpenDialog(this);
			if(result == JFileChooser.APPROVE_OPTION) {
				File[] ausgewählteDateien = chooser.getSelectedFiles();
				Arrays.sort(ausgewählteDateien, (f1, f2) -> f1.getName().compareToIgnoreCase(f2.getName()));
				List<String[]> Ergebnis = new ArrayList<>();
				int longestFile = 0;
				int knotenLänge = 0;
				int kantenLänge = 0;
				int pfadLänge = 0;
				int pfad = 0;
				int m = 0;
				int mm = 0;
				for (File file: ausgewählteDateien) {
					textAusgeben("Datei " + file.getName() + " wird verarbeitet");
					if (file.getName().length()>longestFile) {
						longestFile = file.getName().length();
					}
				    Ergebnis.add(analyseOhneGrafik(file));
				}
				for (String[] erg: Ergebnis) {
					if (erg.length==2) {
						if (erg[0].length() > knotenLänge) {
							knotenLänge = erg[0].length();
						}
						if (erg[1].length() > kantenLänge) {
							kantenLänge = erg[1].length();
						}
					}
					if (erg.length==4) {
						if (erg[0].length() > pfadLänge) {
							pfadLänge = erg[0].length();
						}
						if (erg[1].length() > pfad) {
							pfad = erg[1].length();
						}
						if (erg[2].length() > m) {
							m = erg[2].length();
						}
						if (erg[3].length() > mm) {
							mm = erg[3].length();
						}
					}
				}
				int ges = pfadLänge + pfad + m + mm;
				ges = (ges != 0) ? ges : 21;
				textAusgeben(String.format("%-"+ longestFile +"s %-3s %-10s %-3s %-" + ges + "s", "", " | ", "", " | ", "Knoten / Kanten bzw."));
				textAusgeben(String.format("%-"+ longestFile +"s %-3s %-10s %-3s %-" + ges + "s", "Dateiname", " | ", "beschränkt", " | ", "Pfadlänge: Pfad; m, m'"));
				textAusgeben(String.format("%-"+ longestFile +"s %-1s %-12s %-1s %-" + ges + "s", "-".repeat(longestFile+1), "|", "-".repeat(12), "|", "-".repeat(ges+2)));
				for (int i = 0; i<ausgewählteDateien.length; i++) {
					String name = ausgewählteDateien[i].getName();
					String[] erg= Ergebnis.get(i);
					if (erg.length == 2) {
						textAusgeben(String.format("%-"+ longestFile +"s %-3s %-10s %-3s %-" + ges + "s", name, " | ", "ja", " | ", erg[0] + " / " + erg[1]));
					} else {
						int zw = pfadLänge + pfad + 4;
						textAusgeben(String.format("%-"+ longestFile +"s %-3s %-10s %-3s %-" + zw + "s %-" + (m+2) + "s %-" + (mm+2) + "s", name, " | ", "nein", " | ", erg[0] + ":(" + erg[1] +");", erg[2], erg[3]));
					}
				}
			}
		});
		
		
		titelLabel = new JLabel("Constantin Salzer" + "  |  q3756556", SwingConstants.CENTER);
		toolBar = new JToolBar();
		toolBar.setFloatable(false);
		obereAnzeigefläche = new JSplitPane (JSplitPane.VERTICAL_SPLIT, toolBar, titelLabel);
		this.add(obereAnzeigefläche, BorderLayout.NORTH);
