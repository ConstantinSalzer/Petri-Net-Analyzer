		ImageIcon plus = new ImageIcon ("resources/Bilder/plus.png");
		markePlus = new JButton(plus);
		markePlus.setToolTipText("erhöhe die Anzahl der Marken einer Stelle um 1");
		toolBar.add(markePlus);
		markePlus.addActionListener(e->{
			if (letzteGeöffneteDatei == null) {
				textAusgeben("Sie müssen zuerst eine Datei öffnen");
			} else
			if (!petriGraf.stelleAngeklickt) {
