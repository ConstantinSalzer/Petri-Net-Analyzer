				statusLabel.setToolTipText("Diese Datei wurde substanziell modifiziert");
				petriGraf.erneuereKnotenStil();
				petrinetz.setzeAnfangsmarkierung();
				petrinetz.setzeErstenEGKnoten();
				initialisierepEG();
				petriGraf.stelleGedruckt(petriGraf.angeklickteStelle.getId(),true);
			}
		});
		
		ImageIcon minus = new ImageIcon ("resources/Bilder/minus.png");
		markeMinus = new JButton(minus);
		markeMinus.setToolTipText("verringere die Anzahl der Marken einer Stelle um 1");
		toolBar.add(markeMinus);
		markeMinus.addActionListener(e->{
			if (letzteGeöffneteDatei == null) {
				textAusgeben("Sie müssen zuerst eine Datei öffnen");
			} else
			if (!petriGraf.stelleAngeklickt) {
				textAusgeben("Sie müssen zuerst eine Stelle anklicken");
			} else if (petriGraf.angeklickteStelle.getMarkenzahl()==0){
				textAusgeben("Anzahl der Marken kann nicht mehr verringert werden");
			} else {
				petriGraf.angeklickteStelle.verringereMarkenzahl();
				statusLabel.setIcon(bearbeitet);
				statusLabel.setToolTipText("Diese Datei wurde substanziell modifiziert");
				petriGraf.erneuereKnotenStil();
				petrinetz.setzeAnfangsmarkierung();
				petrinetz.setzeErstenEGKnoten();
				initialisierepEG();
				petriGraf.stelleGedruckt(petriGraf.angeklickteStelle.getId(),true);
			}
		});
		
		ImageIcon reset = new ImageIcon("resources/Bilder/reset.png");
		resetAnfangsmarkierung = new JButton (reset);
		resetAnfangsmarkierung.setToolTipText("setze die die Markierung auf die Anfangsmarkierung zurück");
		toolBar.add(resetAnfangsmarkierung);
		
		resetAnfangsmarkierung.addActionListener(e->{
			if (aktuelleDatei == null) {
				textAusgeben("Sie müssen zuerst eine Datei öffnen");
			} else {
				petrinetz.zuruckzurAnfangsmarkierung();
				petriGraf.erneuereKnotenStil();
				erreichbarkeitsGraf.markiereKnoten(petrinetz.ErreichbarkeitsGraf.anfangsKnoten.getId());
			}
		});
		
		ImageIcon analyseIcon = new ImageIcon("resources/Bilder/analyse.png");
		analyse = new JButton (analyseIcon);
		analyse.setToolTipText("analysiert, ob das Petrinetz beschränkt oder unbeschränkt ist");
		toolBar.add(analyse);
		analyse.addActionListener(e-> {
			petrinetz.zuruckzurAnfangsmarkierung();
			petriGraf.erneuereKnotenStil();
			initialisierepEG();
			if(petrinetz.überprüfeBeschränktheit()) {
				JOptionPane.showMessageDialog(this,
						"Das Petrinetz ist beschränkt"
						);
				textAusgeben("Das Petrinetz ist beschränkt und besteht aus " + petrinetz.ErreichbarkeitsGraf.egKnoten.size() + " Knoten und " + petrinetz.ErreichbarkeitsGraf.egKanten.size() + " Kanten.");
				erreichbarkeitsGraf.updateGraf(null, null, false, false);
				petrinetz.zuruckzurAnfangsmarkierung();
				petriGraf.erneuereKnotenStil();
				erreichbarkeitsGraf.markiereKnoten(petrinetz.ErreichbarkeitsGraf.anfangsKnoten.getId());
				
				
			} else {
				JOptionPane.showMessageDialog(this,
						"Das Petrinetz ist unbeschränkt"
						);
				textAusgeben("Das Petrinetz ist unbeschränkt");
				System.out.println(petrinetz.ErreichbarkeitsGraf.pfadmmm);
				String transitionen = new String();
				for (String trans: this.petrinetz.ErreichbarkeitsGraf.pfadmmm) {
					int index = trans.indexOf("(");
					if (transitionen.length()>1) {
						transitionen = transitionen + ", ";
					}
					transitionen = transitionen + trans.substring(0, index);
				}
				
				textAusgeben("Die Pfadlänge zwischen m und m' ist " + petrinetz.ErreichbarkeitsGraf.pfadmmm.size() + " und besteht aus den Transitionen: " + transitionen);
				textAusgeben("Der Knoten m hat die id: " + this.petrinetz.ErreichbarkeitsGraf.m.getId());
				textAusgeben("Der Knoten m' hat die id: " + this.petrinetz.ErreichbarkeitsGraf.mm.getId());
				
				erreichbarkeitsGraf.updateGraf(null, null, false, true);
				petrinetz.zuruckzurAnfangsmarkierung();
				petriGraf.erneuereKnotenStil();
			}
		});
		this.setVisible(true);
	}
	private String[] analyseOhneGrafik(File pnmlDatei) {
		SpecializedPNMLParser parser = new SpecializedPNMLParser(pnmlDatei);
		parser.initParser();
		parser.parse();
		Petrinetz petri = parser.getfertigesPetrinetz();
		if (petri.überprüfeBeschränktheit()) {
			String[] Ergebnis = new String[2];
			Ergebnis[0] = Integer.toString(petri.ErreichbarkeitsGraf.egKnoten.size());
			Ergebnis[1] = Integer.toString(petri.ErreichbarkeitsGraf.egKanten.size());
			return Ergebnis;
		} else {
			String[] Ergebnis = new String[4];
			String transitionen = new String();
			for (String trans: petri.ErreichbarkeitsGraf.pfadmmm) {
				int index = trans.indexOf("(");
				if (transitionen.length()>1) {
					transitionen = transitionen + ", ";
				}
				transitionen = transitionen + trans.substring(0, index);
			}
			Ergebnis[0] = Integer.toString(petri.ErreichbarkeitsGraf.pfadmmm.size());
			Ergebnis[1] = transitionen;
			Ergebnis[2] = petri.ErreichbarkeitsGraf.m.getId();
			Ergebnis[3] = petri.ErreichbarkeitsGraf.mm.getId();
			return Ergebnis;
		}
	}
	
	
	private void updatePetriGraf(File pnmlDatei) {
		aktuelleDatei = pnmlDatei;
		if (jpnlPetri != null) {
			this.grafAnzeigefläche.remove(jpnlPetri);
		}
		SpecializedPNMLParser speziellerpnmlParser = new SpecializedPNMLParser(pnmlDatei);
		speziellerpnmlParser.initParser();
		speziellerpnmlParser.parse();
		petrinetz = speziellerpnmlParser.getfertigesPetrinetz();
		this.petriGraf=new PetriGraf(petrinetz);
		this.petriGraf.setAttribute("ui.class", "graph");
		initPanelPetriGraph(petriGraf);
		jpnlPetri = new JPanel (new BorderLayout());
		jpnlPetri.add(BorderLayout.CENTER, viewPanelPetri);
		this.grafAnzeigefläche.setLeftComponent(jpnlPetri);
		
		initialisierepEG();
		
		statusLabel.setText("Dateiname: " + aktuelleDatei.getName() );
		ImageIcon nochNichtBearbeitet = new ImageIcon("resources/Bilder/nochnichtbearbeitet.png");
		statusLabel.setIcon(nochNichtBearbeitet);
		statusLabel.setToolTipText("Diese Datei wurde nicht bearbeitet");
		this.revalidate();
		this.repaint();
	}
	
	private void ladeNachbarDatei (boolean nächste) {
		if (letzteGeöffneteDatei == null) {
			textAusgeben("Sie müssen zuerst eine Datei öffnen");
		} else {
			File Verzeichnis = aktuelleDatei.getParentFile();
			File[] listeDateien = Verzeichnis.listFiles((dir, name) -> name.toLowerCase().endsWith(".pnml"));
			List<File> pnmlDateien = Arrays.asList(listeDateien);
			pnmlDateien.sort((f1, f2) -> f1.getName().compareToIgnoreCase(f2.getName()));
			if (pnmlDateien.size()<2) {
				textAusgeben("Es können keine Nachbardateien angezeigt werden, da nur eine PNML-Datei im Verzeichnis existiert!");
			} else {
				int aktuellerIndex = 0;
				for (int i = 0; i < pnmlDateien.size(); i++) {
					if (pnmlDateien.get(i).equals(aktuelleDatei)) {
						aktuellerIndex = i;
					}
				}
				int neueIndex;
			    if (nächste) {
			        neueIndex = (aktuellerIndex + 1) % pnmlDateien.size();
			    } else {
			        neueIndex = (aktuellerIndex - 1 + pnmlDateien.size()) % pnmlDateien.size();
			    }
			    updatePetriGraf(pnmlDateien.get(neueIndex));
			}
		}
	}
	
	
	private void textAusgeben(String text) {
		textPlatzhalter.append(text + "\n");
		textPlatzhalter.setCaretPosition(textPlatzhalter.getDocument().getLength());
	}
	
	private void initPanelPetriGraph(PetriGraf graf) {
		SwingViewer viewer = new SwingViewer(graf,
				Viewer.ThreadingModel.GRAPH_IN_ANOTHER_THREAD);
		
		graf.setAttribute("ui.quality");
		graf.setAttribute("ui.antialias");
		
		viewer.disableAutoLayout();
		
		viewPanelPetri = (ViewPanel) viewer.addDefaultView(false);
		
		ViewerPipe viewerPipe = viewer.newViewerPipe();
		
		ClickListener clickListener = new ClickListener(this);
		
		viewerPipe.addViewerListener(clickListener);
		
		
		viewPanelPetri.addMouseListener(new MouseAdapter() {
			
			@Override
			public void mousePressed(MouseEvent me) {
				System.out.println("Rahmen - mousePressed: " + me);
				viewerPipe.pump();
			}
			
			@Override
			public void mouseReleased(MouseEvent me) {
				System.out.println("Rahmen - mouseReleased: " +me);
				viewerPipe.pump();
			}
		});
		
		viewPanelPetri.addMouseWheelListener(new MouseWheelListener() {
			public void mouseWheelMoved(MouseWheelEvent e) {
				double zoomLevel = viewPanelPetri.getCamera().getViewPercent();
				if (e.getWheelRotation() == -1) {
					zoomLevel -= 0.1;
					if (zoomLevel < 0.1) {
						zoomLevel = 0.1;
					}
				}
				if (e.getWheelRotation() == 1) {
					zoomLevel += 0.1;
				}
				viewPanelPetri.getCamera().setViewPercent(zoomLevel);
			}
		});
	}
	
	private void initPanelErreichbarkeitsGraph(ErreichbarkeitsGraf graf) {
		SwingViewer viewer = new SwingViewer(graf,
				Viewer.ThreadingModel.GRAPH_IN_ANOTHER_THREAD);
		
		graf.setAttribute("ui.quality");
		graf.setAttribute("ui.antialias");
		
		
		viewPanelpEG = (ViewPanel) viewer.addDefaultView(false);
		
		viewer.enableAutoLayout();
		
		ViewerPipe viewerPipe = viewer.newViewerPipe();
		
		ClickListener clickListener = new ClickListener(this);
		
		viewerPipe.addViewerListener(clickListener);
		
		viewPanelpEG.addMouseListener(new MouseAdapter() {
			
			@Override
			public void mousePressed(MouseEvent me) {
				System.out.println("Rahmen - mousePressed: " + me);
				viewerPipe.pump();
			}
			
			@Override
			public void mouseReleased(MouseEvent me) {
				System.out.println("Rahmen - mouseReleased: " +me);
				viewerPipe.pump();
			}
		});
		
		viewPanelpEG.addMouseWheelListener(new MouseWheelListener() {
			public void mouseWheelMoved(MouseWheelEvent e) {
				double zoomLevel = viewPanelpEG.getCamera().getViewPercent();
				if (e.getWheelRotation() == -1) {
					zoomLevel -= 0.1;
					if (zoomLevel < 0.1) {
						zoomLevel = 0.1;
					}
				}
				if (e.getWheelRotation() == 1) {
					zoomLevel += 0.1;
				}
				viewPanelpEG.getCamera().setViewPercent(zoomLevel);
			}
		});
	}
	
	public void rahmenKnotenGedruckt(String id) {
		if (erreichbarkeitsGraf.getNode(id)!= null) {
			petrinetz.setzeBestimmteMarkierung(id);
			petriGraf.erneuereKnotenStil();
			erreichbarkeitsGraf.markiereKnoten(id);
			petrinetz.ErreichbarkeitsGraf.setAktuelleMarkierung(petrinetz.ErreichbarkeitsGraf.egKnoten.get(id));
		} else if (petrinetz.Stellen.containsKey(id)) {
			petriGraf.stelleGedruckt(id, false);
		} else {
			petriGraf.transitionGedruckt(id);
			erreichbarkeitsGraf.updateGraf(id, petrinetz.EGKnotenName(), true, false);
		}
	}
	
	void initialisierepEG() {
		petrinetz.setzeErstenEGKnoten();
		this.erreichbarkeitsGraf = new ErreichbarkeitsGraf(petrinetz.ErreichbarkeitsGraf);
		erreichbarkeitsGraf.initilisiere();
		initPanelErreichbarkeitsGraph(erreichbarkeitsGraf);
		jpnlpEG = new JPanel (new BorderLayout());
		jpnlpEG.add(BorderLayout.CENTER, viewPanelpEG);
		this.grafAnzeigefläche.setRightComponent(jpnlpEG);
	}
}
