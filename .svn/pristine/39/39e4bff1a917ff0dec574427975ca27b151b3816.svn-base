		vorherigepnmlDatei.setToolTipText("öffne alphabetisch vorherige PNML-Datei aus dem zuletzt verwendeten Verzeichnis.");
		toolBar.add(vorherigepnmlDatei);
		vorherigepnmlDatei.addActionListener(e->{
			ladeNachbarDatei(false);
		});
		
		ImageIcon nächsteIcon = new ImageIcon ("resources/Bilder/nächstePNMLDatei.png");
		nächstepnmlDatei = new JButton(nächsteIcon);
		nächstepnmlDatei.setToolTipText("öffne alphabetisch nächste PNML-Datei aus dem zuletzt verwendeten Verzeichnis");
		toolBar.add(nächstepnmlDatei);
		nächstepnmlDatei.addActionListener(e->{
			ladeNachbarDatei(true);
		});
		
		ImageIcon lösche = new ImageIcon ("resources/Bilder/löscheEG.png");
		löscheEG = new JButton(lösche);
		löscheEG.setToolTipText("lösche aktuellen Erreichbarkeits-Grafen und setze markierung auf Anfangsmarkierung zurück");
		toolBar.add(löscheEG);
		löscheEG.addActionListener(e->{
			if (aktuelleDatei == null) {
				textAusgeben("Sie müssen zuerst eine Datei öffnen");
			} else if (erreichbarkeitsGraf.getNodeCount()<2){
