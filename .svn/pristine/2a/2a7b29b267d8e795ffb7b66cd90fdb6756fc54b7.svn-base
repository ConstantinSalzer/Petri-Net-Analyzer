package exceptions;

/**
 *Exception falls eine Kante nicht richtig konfiguriert wurde 
 */
public class UngültigeKanteException extends RuntimeException{
	private static final long serialVersionUID = 1L;

	/**
	 * Konstruktor der Exception
	 * @param id 
	 * 				ID des Elements durch das die Exception geworfen wurde
	 */
	public UngültigeKanteException(String id) {
		super("Kante mit ID: " + id + " ist ungültig!");
	}

}
