package exceptions;

/**
 * Exception falls einem Element eine Fehlerhafte Position zugewiesen wurde
 */
public class FehlerhaftePositionException extends RuntimeException{
	private static final long serialVersionUID = 1L;
	/**
	 * Konstruktor der Exception, der die passende Fehlermeldung ausgibt
	 * @param id
	 * 		ID des Elements, dass die Fehlermeldung ausgelöst hat
	 */
	public FehlerhaftePositionException (String id) {
		super("Dem Element mit der ID: " + id + " wurde eine fehlerhafte Position zugewiesen!");
	}
}
