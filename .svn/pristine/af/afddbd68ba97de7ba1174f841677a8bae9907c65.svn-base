package exceptions;

/**
 * Exception, falls bereits eine Stellt mit der selben ID existiert
 */
public class DoppelteStelleException extends RuntimeException{
	private static final long serialVersionUID = 1L;

	/**
	 * Konstruktor der Exception, der die passende Fehlermeldung ausgibt
	 * @param id
	 * 		ID des Elements, dass die Fehlermeldung ausgelöst hat
	 */
	public DoppelteStelleException (String id) {
		super("Stelle mit ID: " + id + " existiert bereits!");
	}

}
