package datenstruktur;


/**
 * Diese Klasse implementiert Knoten in Erreichbarkeitsgraphen und erbt dafür von der Klasse Knoten
 */
public class EGKnoten extends Knoten{
	
	
	/**
	 * Konstruktor mit der Objekte dieser Klasse erzeugt werden
	 * @param id
	 * 				String Parameter mit der ID des zu erstellenden Knoten
	 */
	public EGKnoten(String id) {
		super(id);
		super.setName(id);
	}
}
