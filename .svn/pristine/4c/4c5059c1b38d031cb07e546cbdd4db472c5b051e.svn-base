package Petrinets_3756556_Salzer_Constantin;
import java.io.File;
import java.util.Map;

import GUI.Graf;
import GUI.Rahmen;
import datenstruktur_Petrinetz.Petrinetz;
import datenstruktur_Petrinetz.SpecializedPNMLParser;
import datenstruktur_Petrinetz.Stelle;

public class Petrinets_3756556_Salzer_Constantin {

	public static void main(String[] args) {
		Petrinetz petrinetz = new Petrinetz();
		if (args.length>0) {
			File pnmlDatei = new File (args[0]);
			if (pnmlDatei.exists()) {
				SpecializedPNMLParser speziellerpnmlParser = new SpecializedPNMLParser(pnmlDatei, new Petrinetz());
				speziellerpnmlParser.initParser();
				speziellerpnmlParser.parse();
				petrinetz = speziellerpnmlParser.petrinetz;
			} else {
				System.err.println("Die Datei " + pnmlDatei.getAbsolutePath()
				+ " wurde nicht gefunden!");
			}
		} else {
			System.out.println("Bitte eine Datei als Parameter angeben!");
		}
		Graf graf = new Graf(petrinetz);
		Rahmen rahmen = new Rahmen("test", graf);
	}
}
